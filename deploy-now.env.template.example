# Для IONOS Deploy Now workflow v2 положите это содержимое в:
# .deploy-now/<project-name>/.env.template
DEUTSCHGRAM_DB_DRIVER=mysql
DEUTSCHGRAM_DB_HOST=$IONOS_DB_HOST
DEUTSCHGRAM_DB_PORT=3306
DEUTSCHGRAM_DB_NAME=$IONOS_DB_NAME
DEUTSCHGRAM_DB_USER=$IONOS_DB_USERNAME
DEUTSCHGRAM_DB_PASSWORD=$IONOS_DB_PASSWORD
DEUTSCHGRAM_DB_CHARSET=utf8mb4