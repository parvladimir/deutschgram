# Recommended production configuration for IONOS MariaDB / MySQL
DEUTSCHGRAM_DB_DRIVER=mysql
DEUTSCHGRAM_DB_HOST=127.0.0.1
DEUTSCHGRAM_DB_PORT=3306
DEUTSCHGRAM_DB_NAME=deutschgram
DEUTSCHGRAM_DB_USER=deutschgram_user
DEUTSCHGRAM_DB_PASSWORD=change-me
DEUTSCHGRAM_DB_CHARSET=utf8mb4

# Optional local SQLite fallback
# DEUTSCHGRAM_DB_DRIVER=sqlite
# DEUTSCHGRAM_DB_PATH=storage/deutschgram.sqlite
